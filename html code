<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MandiBhav — Live Mandi Prices</title>
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/recharts@2.8.0/umd/Recharts.js"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f9fafb;color:#111827;min-height:100vh}
  input,select,textarea,button{font-family:inherit}
  button{cursor:pointer}
  .hidden{display:none!important}

  /* NAV */
  nav{background:#fff;border-bottom:1px solid #e5e7eb;position:sticky;top:0;z-index:100;padding:0 1.5rem}
  .nav-inner{max-width:1100px;margin:0 auto;height:58px;display:flex;align-items:center;justify-content:space-between}
  .logo{display:flex;align-items:center;gap:8px;text-decoration:none}
  .logo-text{font-weight:700;font-size:18px;color:#16a34a}
  .live-badge{font-size:10px;background:#dcfce7;color:#15803d;padding:2px 8px;border-radius:20px;font-weight:600}
  .nav-links{display:flex;align-items:center;gap:4px}
  .nav-btn{padding:6px 14px;border-radius:8px;border:none;background:none;font-size:14px;font-weight:500;color:#374151;cursor:pointer;transition:background .15s}
  .nav-btn:hover{background:#f3f4f6}
  .nav-btn.active{color:#16a34a;background:#f0fdf4}
  .nav-register{background:#16a34a;color:#fff!important;padding:7px 16px;border-radius:8px}
  .nav-register:hover{background:#15803d!important}

  /* LAYOUT */
  .page{display:none;max-width:1100px;margin:0 auto;padding:2rem 1.5rem}
  .page.active{display:block}

  /* STATS ROW */
  .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:1.5rem}
  .stat-card{background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1rem}
  .stat-icon{font-size:20px;margin-bottom:4px}
  .stat-val{font-size:22px;font-weight:800;color:#111827}
  .stat-label{font-size:12px;color:#6b7280;margin-top:2px}
  .stat-sub{font-size:11px;color:#16a34a;font-weight:500}

  /* FILTERS */
  .filters{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:1.5rem;align-items:center}
  .filters select,.filters input{padding:8px 12px;border-radius:8px;border:1px solid #e5e7eb;font-size:14px;background:#fff;color:#374151;outline:none}
  .filters input{flex:1;min-width:180px}
  .cat-pills{display:flex;gap:6px;flex-wrap:wrap}
  .cat-pill{padding:6px 14px;border-radius:20px;border:1px solid #e5e7eb;background:#fff;font-size:13px;font-weight:500;color:#6b7280;transition:all .15s}
  .cat-pill.active{border-color:#16a34a;background:#f0fdf4;color:#16a34a}

  /* PRICE GRID */
  .price-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px}
  .price-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:1rem;cursor:pointer;transition:box-shadow .15s,border-color .15s}
  .price-card:hover{box-shadow:0 4px 12px rgba(0,0,0,.08);border-color:#d1d5db}
  .price-card.selected{border-color:#16a34a;box-shadow:0 0 0 2px #dcfce7}
  .pc-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
  .pc-emoji{font-size:24px}
  .pc-price{text-align:right}
  .pc-amount{font-size:22px;font-weight:800;color:#16a34a}
  .pc-unit{font-size:11px;color:#9ca3af}
  .pc-name{font-weight:700;font-size:15px;color:#111827}
  .pc-cat{font-size:12px;color:#6b7280;margin-bottom:8px}
  .pc-divider{border:none;border-top:1px solid #f3f4f6;margin:8px 0}
  .pc-mandi{font-size:13px;font-weight:600;color:#374151}
  .pc-loc{font-size:12px;color:#6b7280;margin-top:2px}
  .pc-stock{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;margin-top:8px}
  .stock-available{background:#dcfce7;color:#15803d}
  .stock-limited{background:#fef3c7;color:#92400e}
  .stock-out{background:#fee2e2;color:#991b1b}
  .stock-dot{width:6px;height:6px;border-radius:50%;display:inline-block}

  /* CHART */
  .chart-box{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:1.25rem;margin-bottom:1.5rem}
  .chart-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
  .chart-title{font-size:15px;font-weight:700;color:#111827}
  .chart-sub{font-size:12px;color:#6b7280;margin-top:2px}
  .day-pills{display:flex;gap:6px}
  .day-pill{padding:4px 12px;border-radius:6px;border:1px solid #e5e7eb;background:#fff;font-size:12px;font-weight:500;color:#6b7280}
  .day-pill.active{border-color:#16a34a;background:#f0fdf4;color:#16a34a}
  .chart-area{height:200px;position:relative}
  .chart-svg{width:100%;height:100%}

  /* COMPARE */
  .compare-controls{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:1.25rem;margin-bottom:1.5rem;display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end}
  .form-group{flex:1;min-width:140px}
  .form-label{font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:5px}
  .form-input{width:100%;padding:9px 12px;border-radius:8px;border:1px solid #e5e7eb;font-size:14px;outline:none}
  .btn-primary{padding:9px 24px;background:#16a34a;color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600}
  .btn-primary:hover{background:#15803d}
  .compare-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1.5rem}
  .cmp-stat{border-radius:10px;padding:1rem;text-align:center}
  .cmp-val{font-size:20px;font-weight:800}
  .cmp-label{font-size:12px;margin-top:2px;font-weight:500}
  .compare-table{background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden}
  table{width:100%;border-collapse:collapse;font-size:14px}
  th{padding:11px 14px;text-align:left;font-weight:600;color:#374151;font-size:12px;background:#f9fafb;border-bottom:1px solid #e5e7eb}
  td{padding:11px 14px;border-bottom:1px solid #f3f4f6}
  tr:last-child td{border-bottom:none}
  tr.best-row{background:#f0fdf4}
  .rank-badge{font-size:16px}
  .price-cell{font-weight:700;color:#16a34a;font-size:15px}
  .stock-badge{padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600}
  .savings-best{color:#15803d;font-weight:600}

  /* ALERTS */
  .alerts-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
  @media(max-width:640px){.alerts-grid{grid-template-columns:1fr}}
  .card-box{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:1.5rem}
  .card-title{font-size:16px;font-weight:700;color:#111827;margin-bottom:1rem}
  .form-stack{display:flex;flex-direction:column;gap:12px}
  .alert-item{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-radius:8px;border:1px solid #e5e7eb;background:#f9fafb;margin-bottom:8px}
  .alert-item.triggered{background:#f0fdf4;border-color:#bbf7d0}
  .alert-name{font-weight:600;font-size:14px;color:#111827}
  .alert-detail{font-size:12px;color:#6b7280;margin-top:2px}
  .triggered-badge{font-size:10px;background:#dcfce7;color:#15803d;padding:2px 8px;border-radius:20px;font-weight:600;margin-left:8px}
  .del-btn{background:none;border:none;color:#ef4444;font-size:18px;padding:4px 8px}
  .msg-box{padding:9px 12px;border-radius:6px;font-size:13px;margin-top:4px}
  .msg-ok{background:#f0fdf4;color:#15803d}
  .msg-err{background:#fef2f2;color:#dc2626}

  /* DASHBOARD */
  .dash-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem}
  .dash-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:1.5rem}
  .tabs{display:flex;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;margin-bottom:1.5rem}
  .tab-btn{flex:1;padding:11px;border:none;font-size:14px;font-weight:600;cursor:pointer;transition:background .15s}
  .tab-btn.active{background:#16a34a;color:#fff}
  .tab-btn:not(.active){background:#fff;color:#374151}
  .add-form{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .add-form .full{grid-column:1/-1}
  .my-prices-table{background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden}

  /* AUTH */
  .auth-wrap{min-height:80vh;display:flex;align-items:center;justify-content:center;padding:2rem}
  .auth-box{width:100%;max-width:420px;background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:2rem}
  .auth-center{text-align:center;margin-bottom:1.5rem}
  .auth-icon{font-size:40px}
  .auth-title{font-size:22px;font-weight:800;color:#111827;margin-top:8px}
  .auth-sub{color:#6b7280;margin-top:4px;font-size:14px}
  .auth-form{display:flex;flex-direction:column;gap:14px}
  .auth-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .auth-link{text-align:center;margin-top:1.25rem;font-size:14px;color:#6b7280}
  .auth-link a{color:#16a34a;font-weight:600;cursor:pointer;text-decoration:none}

  /* EMPTY / LOADING */
  .empty{text-align:center;padding:4rem;color:#9ca3af;border:2px dashed #e5e7eb;border-radius:12px}
  .empty-icon{font-size:36px;margin-bottom:8px}
  .loading{text-align:center;padding:4rem;color:#9ca3af}

  /* TOAST */
  .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:#1f2937;color:#fff;padding:12px 24px;border-radius:12px;font-size:14px;font-weight:500;z-index:999;display:none;animation:fadeUp .3s ease}
  @keyframes fadeUp{from{opacity:0;transform:translateX(-50%) translateY(8px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

  /* VENDOR modal */
  .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center;padding:1rem}
  .modal-bg.open{display:flex}
  .modal{background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:480px;max-height:90vh;overflow-y:auto}
  .modal-title{font-size:18px;font-weight:700;margin-bottom:1.25rem}
  .modal-close{float:right;background:none;border:none;font-size:22px;color:#6b7280;cursor:pointer;line-height:1}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav>
  <div class="nav-inner">
    <a class="logo" href="#" onclick="showPage('home');return false">
      <span style="font-size:22px">🥦</span>
      <span class="logo-text">MandiBhav</span>
      <span class="live-badge">LIVE</span>
    </a>
    <div class="nav-links">
      <button class="nav-btn active" id="nav-home" onclick="showPage('home')">Price Board</button>
      <button class="nav-btn" id="nav-compare" onclick="showPage('compare')">Compare</button>
      <button class="nav-btn" id="nav-alerts" onclick="showPage('alerts')">Alerts</button>
      <span id="nav-auth-loggedout">
        <button class="nav-btn" onclick="showPage('login')">Login</button>
        <button class="nav-btn nav-register" style="color:#fff" onclick="showPage('register')">Register Mandi</button>
      </span>
      <span id="nav-auth-loggedin" class="hidden">
        <button class="nav-btn" id="nav-dashboard" onclick="showPage('dashboard')">Dashboard</button>
        <button class="nav-btn" onclick="logout()" style="color:#ef4444">Logout</button>
      </span>
    </div>
  </div>
</nav>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- ===== HOME PAGE ===== -->
<div class="page active" id="page-home">
  <h1 style="font-size:26px;font-weight:800;margin-bottom:4px">Today's Mandi Prices</h1>
  <p style="color:#6b7280;margin-bottom:1.5rem">Live vegetable &amp; grocery prices from local mandis. Click any item to see its trend chart.</p>

  <div class="stats-grid" id="home-stats"></div>

  <!-- Chart -->
  <div class="chart-box hidden" id="chart-container">
    <div class="chart-header">
      <div>
        <div class="chart-title" id="chart-title">Price Trend</div>
        <div class="chart-sub" id="chart-sub"></div>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <div class="day-pills">
          <button class="day-pill active" onclick="setChartDays(7,this)">7D</button>
          <button class="day-pill" onclick="setChartDays(14,this)">14D</button>
          <button class="day-pill" onclick="setChartDays(30,this)">30D</button>
        </div>
        <button onclick="closeChart()" style="background:none;border:none;color:#ef4444;font-size:18px;padding:4px 8px;cursor:pointer">✕</button>
      </div>
    </div>
    <div class="chart-area">
      <svg class="chart-svg" id="chart-svg" viewBox="0 0 700 200" preserveAspectRatio="none"></svg>
    </div>
    <div style="display:flex;gap:16px;margin-top:8px;font-size:12px;color:#6b7280">
      <span><span style="color:#16a34a;font-weight:600">—</span> Avg Price</span>
      <span><span style="color:#3b82f6;font-weight:600">- -</span> Min Price</span>
      <span><span style="color:#ef4444;font-weight:600">- -</span> Max Price</span>
    </div>
  </div>

  <!-- Filters -->
  <div class="filters">
    <select id="city-select" onchange="applyFilters()">
      <option>Bengaluru</option><option>Mumbai</option><option>Delhi</option>
      <option>Chennai</option><option>Hyderabad</option><option>Pune</option>
    </select>
    <input type="text" id="search-input" placeholder="Search item..." oninput="applyFilters()">
    <div class="cat-pills" id="cat-pills"></div>
  </div>

  <div id="price-grid" class="price-grid"></div>
</div>

<!-- ===== COMPARE PAGE ===== -->
<div class="page" id="page-compare">
  <h1 style="font-size:26px;font-weight:800;margin-bottom:4px">Compare Prices</h1>
  <p style="color:#6b7280;margin-bottom:1.5rem">Find the cheapest mandi for any item in your city.</p>

  <div class="compare-controls">
    <div class="form-group">
      <label class="form-label">Item</label>
      <input class="form-input" id="cmp-item" list="item-suggestions" placeholder="e.g. Tomato">
      <datalist id="item-suggestions"></datalist>
    </div>
    <div class="form-group">
      <label class="form-label">City</label>
      <select class="form-input" id="cmp-city">
        <option>Bengaluru</option><option>Mumbai</option><option>Delhi</option>
        <option>Chennai</option><option>Hyderabad</option><option>Pune</option>
      </select>
    </div>
    <button class="btn-primary" onclick="runCompare()">Compare →</button>
  </div>

  <div id="cmp-stats" class="hidden compare-stats"></div>
  <div id="cmp-result"></div>
</div>

<!-- ===== ALERTS PAGE ===== -->
<div class="page" id="page-alerts">
  <h1 style="font-size:26px;font-weight:800;margin-bottom:4px">Price Alerts</h1>
  <p style="color:#6b7280;margin-bottom:1.5rem">Set a target price — get flagged when it drops in your city.</p>

  <div class="alerts-grid">
    <div class="card-box">
      <div class="card-title">🔔 Create Alert</div>
      <div class="form-stack">
        <div>
          <label class="form-label">Your Email</label>
          <input class="form-input" style="width:100%" id="al-email" type="email" placeholder="you@example.com">
        </div>
        <div>
          <label class="form-label">Item</label>
          <input class="form-input" style="width:100%" id="al-item" placeholder="e.g. Tomato">
        </div>
        <div>
          <label class="form-label">City</label>
          <select class="form-input" style="width:100%" id="al-city">
            <option>Bengaluru</option><option>Mumbai</option><option>Delhi</option>
            <option>Chennai</option><option>Hyderabad</option><option>Pune</option>
          </select>
        </div>
        <div>
          <label class="form-label">Alert when price ≤ ₹</label>
          <input class="form-input" style="width:100%" id="al-price" type="number" min="1" placeholder="e.g. 30">
        </div>
        <div id="al-msg"></div>
        <button class="btn-primary" style="width:100%;padding:11px" onclick="createAlert()">Set Alert</button>
      </div>
    </div>

    <div class="card-box">
      <div class="card-title">📋 My Alerts</div>
      <div style="display:flex;gap:8px;margin-bottom:1rem">
        <input class="form-input" style="flex:1" id="al-fetch-email" type="email" placeholder="Enter email to view alerts">
        <button class="btn-primary" onclick="fetchAlerts()">View</button>
      </div>
      <div id="alerts-list"><p style="color:#9ca3af;font-size:14px;text-align:center;padding:1.5rem 0">Enter your email and click View.</p></div>
    </div>
  </div>
</div>

<!-- ===== DASHBOARD PAGE ===== -->
<div class="page" id="page-dashboard">
  <div class="dash-header">
    <div>
      <h1 style="font-size:22px;font-weight:800">Vendor Dashboard</h1>
      <p style="color:#6b7280;margin-top:4px;font-size:14px" id="dash-subtitle"></p>
    </div>
    <button class="btn-primary" onclick="showPage('home')">View Board</button>
  </div>

  <div class="dash-stats" id="dash-stats"></div>

  <div class="tabs">
    <button class="tab-btn active" id="tab-prices" onclick="switchTab('prices')">📋 My Prices</button>
    <button class="tab-btn" id="tab-add" onclick="switchTab('add')">➕ Add / Update Price</button>
  </div>

  <div id="tab-content-prices">
    <div class="my-prices-table" id="my-prices-table"></div>
  </div>

  <div id="tab-content-add" class="hidden">
    <div class="card-box">
      <p style="color:#6b7280;font-size:13px;margin-bottom:1rem">Add a new item or re-post to update today's price.</p>
      <div class="add-form">
        <div>
          <label class="form-label">Item Name</label>
          <input class="form-input" style="width:100%" id="add-item" placeholder="e.g. Tomato">
        </div>
        <div>
          <label class="form-label">Price per unit (₹)</label>
          <input class="form-input" style="width:100%" id="add-price" type="number" step="0.1" min="0" placeholder="e.g. 30">
        </div>
        <div>
          <label class="form-label">Category</label>
          <select class="form-input" style="width:100%" id="add-cat">
            <option>Vegetables</option><option>Fruits</option><option>Grains</option>
            <option>Spices</option><option>Dairy</option><option>Other</option>
          </select>
        </div>
        <div>
          <label class="form-label">Unit</label>
          <select class="form-input" style="width:100%" id="add-unit">
            <option>kg</option><option>dozen</option><option>piece</option>
            <option>litre</option><option>250g</option><option>500g</option>
          </select>
        </div>
        <div>
          <label class="form-label">Stock Status</label>
          <select class="form-input" style="width:100%" id="add-stock">
            <option value="available">Available</option>
            <option value="limited">Limited</option>
            <option value="out_of_stock">Out of Stock</option>
          </select>
        </div>
        <div class="full">
          <div id="add-msg"></div>
          <button class="btn-primary full" style="width:100%;padding:11px;margin-top:4px" onclick="publishPrice()">📤 Publish Price</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ===== LOGIN PAGE ===== -->
<div class="page" id="page-login">
  <div class="auth-wrap">
    <div style="width:100%;max-width:420px">
      <div class="auth-center">
        <div class="auth-icon">🥦</div>
        <div class="auth-title">Vendor Login</div>
        <div class="auth-sub">Sign in to manage your mandi prices</div>
      </div>
      <div class="auth-box">
        <div class="auth-form">
          <div>
            <label class="form-label">Email</label>
            <input class="form-input" style="width:100%" id="login-email" type="email" placeholder="you@example.com">
          </div>
          <div>
            <label class="form-label">Password</label>
            <input class="form-input" style="width:100%" id="login-password" type="password" placeholder="Your password">
          </div>
          <div id="login-msg"></div>
          <button class="btn-primary" style="width:100%;padding:11px" onclick="doLogin()">Sign In</button>
        </div>
        <p class="auth-link">New vendor? <a onclick="showPage('register')">Register your mandi</a></p>
      </div>
    </div>
  </div>
</div>

<!-- ===== REGISTER PAGE ===== -->
<div class="page" id="page-register">
  <div style="max-width:520px;margin:2rem auto">
    <div class="auth-center">
      <div class="auth-icon">🏪</div>
      <div class="auth-title">Register Your Mandi</div>
      <div class="auth-sub">Join vendors publishing daily prices</div>
    </div>
    <div class="auth-box" style="max-width:100%">
      <div class="auth-form-grid">
        <div>
          <label class="form-label">Your Name</label>
          <input class="form-input" style="width:100%" id="reg-name" placeholder="Ramesh Kumar">
        </div>
        <div>
          <label class="form-label">Mandi Name</label>
          <input class="form-input" style="width:100%" id="reg-mandi" placeholder="KR Market">
        </div>
        <div>
          <label class="form-label">City</label>
          <input class="form-input" style="width:100%" id="reg-city" placeholder="Bengaluru">
        </div>
        <div>
          <label class="form-label">Pincode</label>
          <input class="form-input" style="width:100%" id="reg-pin" placeholder="560002">
        </div>
        <div>
          <label class="form-label">Phone</label>
          <input class="form-input" style="width:100%" id="reg-phone" placeholder="9876543210">
        </div>
        <div>
