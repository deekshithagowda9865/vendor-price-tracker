</div>

<script>
// ─── DEMO DATA ────────────────────────────────────────────────────────────────
const MANDIS = [
  { id:'v1', name:'Ramesh Kumar', mandiName:'KR Market', city:'Bengaluru', pincode:'560002', phone:'9876543210', email:'ramesh@krmarket.com', password:'password123' },
  { id:'v2', name:'Suresh Patel', mandiName:'Yeshwanthpur Mandi', city:'Bengaluru', pincode:'560022', phone:'9876543211', email:'suresh@ymandi.com', password:'password123' },
  { id:'v3', name:'Priya Devi', mandiName:'Jayanagar Mandi', city:'Bengaluru', pincode:'560041', phone:'9876543212', email:'priya@jmandi.com', password:'password123' },
  { id:'v4', name:'Ahmed Khan', mandiName:'Crawford Market', city:'Mumbai', pincode:'400001', phone:'9876543213', email:'ahmed@crawford.com', password:'password123' },
  { id:'v5', name:'Sunita Sharma', mandiName:'Azadpur Mandi', city:'Delhi', pincode:'110033', phone:'9876543214', email:'sunita@azadpur.com', password:'password123' }
];

const BASE_PRICES = {
  Tomato:30,Onion:25,Potato:20,Carrot:40,Brinjal:35,Capsicum:60,
  Cabbage:25,Spinach:30,Beans:50,Pumpkin:22,Banana:40,Apple:120,
  Mango:80,Rice:55,Wheat:35,Turmeric:160,Chilli:90,Milk:58
};

const CATEGORIES = {
  Tomato:'Vegetables',Onion:'Vegetables',Potato:'Vegetables',Carrot:'Vegetables',
  Brinjal:'Vegetables',Capsicum:'Vegetables',Cabbage:'Vegetables',Spinach:'Vegetables',
  Beans:'Vegetables',Pumpkin:'Vegetables',Banana:'Fruits',Apple:'Fruits',Mango:'Fruits',
  Rice:'Grains',Wheat:'Grains',Turmeric:'Spices',Chilli:'Spices',Milk:'Dairy'
};

const EMOJIS = {
  Vegetables:'🥬',Fruits:'🍎',Grains:'🌾',Spices:'🌶️',Dairy:'🥛',Other:'📦'
};

// Generate price history (30 days)
function genPrices() {
  const prices = [];
  const today = new Date(); today.setHours(0,0,0,0);
  MANDIS.forEach(v => {
    Object.entries(BASE_PRICES).forEach(([item, base]) => {
      for(let d = 29; d >= 0; d--) {
        const date = new Date(today); date.setDate(date.getDate() - d);
        const variation = (Math.random() - 0.5) * base * 0.3;
        prices.push({
          id: `${v.id}-${item}-${d}`,
          vendorId: v.id,
          item, category: CATEGORIES[item],
          pricePerKg: Math.max(5, Math.round((base + variation) * 10) / 10),
          unit: item === 'Milk' ? 'litre' : 'kg',
          stock: Math.random() > 0.1 ? 'available' : (Math.random() > 0.5 ? 'limited' : 'out_of_stock'),
          date: new Date(date)
        });
      }
    });
  });
  return prices;
}

// ─── APP STATE ────────────────────────────────────────────────────────────────
let allPrices = genPrices();
let vendors = [...MANDIS];
let alerts = JSON.parse(localStorage.getItem('mandibhav_alerts') || '[]');
let currentVendor = JSON.parse(localStorage.getItem('mandibhav_vendor') || 'null');
let selectedItem = null;
let chartDays = 7;
let activeCategory = 'All';
let currentDashTab = 'prices';

function saveAlerts() { localStorage.setItem('mandibhav_alerts', JSON.stringify(alerts)); }

// ─── NAVIGATION ───────────────────────────────────────────────────────────────
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  const nb = document.getElementById('nav-' + name);
  if (nb) nb.classList.add('active');
  if (name === 'home') renderHome();
  if (name === 'dashboard') renderDashboard();
  if (name === 'compare') populateItemSuggestions();
}

function updateAuthNav() {
  if (currentVendor) {
    document.getElementById('nav-auth-loggedout').classList.add('hidden');
    document.getElementById('nav-auth-loggedin').classList.remove('hidden');
  } else {
    document.getElementById('nav-auth-loggedout').classList.remove('hidden');
    document.getElementById('nav-auth-loggedin').classList.add('hidden');
  }
}

// ─── HOME ─────────────────────────────────────────────────────────────────────
const ALL_CATS = ['All','Vegetables','Fruits','Grains','Spices','Dairy','Other'];

function getTodayPrices(city) {
  const today = new Date(); today.setHours(0,0,0,0);
  return allPrices.filter(p => {
    const pd = new Date(p.date); pd.setHours(0,0,0,0);
    const v = vendors.find(v => v.id === p.vendorId);
    return pd.getTime() === today.getTime() && v && v.city.toLowerCase() === city.toLowerCase();
  }).map(p => ({ ...p, vendor: vendors.find(v => v.id === p.vendorId) }));
}

function renderHome() {
  renderCatPills();
  applyFilters();
}

function renderCatPills() {
  const el = document.getElementById('cat-pills');
  el.innerHTML = ALL_CATS.map(c =>
    `<button class="cat-pill${c === activeCategory ? ' active' : ''}" onclick="setCategory('${c}')">${c}</button>`
  ).join('');
}

function setCategory(c) {
  activeCategory = c;
  renderCatPills();
  applyFilters();
}

function applyFilters() {
  const city = document.getElementById('city-select').value;
  const search = document.getElementById('search-input').value.toLowerCase();
  let prices = getTodayPrices(city);
  if (activeCategory !== 'All') prices = prices.filter(p => p.category === activeCategory);
  if (search) prices = prices.filter(p => p.item.toLowerCase().includes(search));

  // Deduplicate: keep cheapest per item per vendor
  const seen = new Set();
  const deduped = [];
  prices.forEach(p => {
    const key = `${p.vendorId}-${p.item}`;
    if (!seen.has(key)) { seen.add(key); deduped.push(p); }
  });

  renderStats(deduped, city);
  renderGrid(deduped);
}

function renderStats(prices, city) {
  const vendorSet = new Set(prices.map(p => p.vendorId));
  const sorted = [...prices].sort((a,b) => a.pricePerKg - b.pricePerKg);
  const cheapest = sorted[0];
  document.getElementById('home-stats').innerHTML = [
    { icon:'📋', val: prices.length, label:'Prices Listed' },
    { icon:'🏪', val: vendorSet.size, label:'Active Mandis', sub: city },
    { icon:'📉', val: cheapest ? `₹${cheapest.pricePerKg}` : '—', label:'Lowest Today', sub: cheapest?.item }
  ].map(s => `
    <div class="stat-card">
      <div class="stat-icon">${s.icon}</div>
      <div class="stat-val">${s.val}</div>
      <div class="stat-label">${s.label}</div>
      ${s.sub ? `<div class="stat-sub">${s.sub}</div>` : ''}
    </div>`).join('');
}

function renderGrid(prices) {
  const el = document.getElementById('price-grid');
  if (prices.length === 0) {
    el.innerHTML = `<div class="empty" style="grid-column:1/-1">
      <div class="empty-icon">🔍</div>
      <p>No prices found. Try a different city or category.</p>
    </div>`; return;
  }
  el.innerHTML = prices.map(p => {
    const stockClass = p.stock === 'available' ? 'stock-available' : p.stock === 'limited' ? 'stock-limited' : 'stock-out';
    const stockLabel = p.stock === 'available' ? 'In Stock' : p.stock === 'limited' ? 'Limited' : 'Out of Stock';
    const dotColor = p.stock === 'available' ? '#16a34a' : p.stock === 'limited' ? '#d97706' : '#ef4444';
    const isSelected = selectedItem === p.item ? ' selected' : '';
    return `<div class="price-card${isSelected}" onclick="selectItem('${p.item}')">
      <div class="pc-header">
        <div>
          <div class="pc-emoji">${EMOJIS[p.category] || '📦'}</div>
          <div class="pc-name">${p.item}</div>
          <div class="pc-cat">${p.category}</div>
        </div>
        <div class="pc-price">
          <div class="pc-amount">₹${p.pricePerKg}</div>
          <div class="pc-unit">per ${p.unit}</div>
        </div>
      </div>
      <hr class="pc-divider">
      <div class="pc-mandi">🏪 ${p.vendor?.mandiName}</div>
      <div class="pc-loc">📍 ${p.vendor?.city} · ${p.vendor?.pincode}</div>
      ${p.vendor?.phone ? `<div class="pc-loc">📞 ${p.vendor.phone}</div>` : ''}
      <div class="pc-stock ${stockClass}">
        <span class="stock-dot" style="background:${dotColor}"></span>${stockLabel}
      </div>
    </div>`;
  }).join('');
}

// ─── CHART ────────────────────────────────────────────────────────────────────
function selectItem(item) {
  selectedItem = item;
  document.getElementById('chart-container').classList.remove('hidden');
  document.getElementById('chart-title').textContent = `📈 ${item} — Price Trend`;
  const city = document.getElementById('city-select').value;
  document.getElementById('chart-sub').textContent = `in ${city} · ₹ per unit`;
  drawChart(item, city, chartDays);
  applyFilters(); // re-render grid to show selected
}

function setChartDays(d, btn) {
  chartDays = d;
  document.querySelectorAll('.day-pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  const city = document.getElementById('city-select').value;
  if (selectedItem) drawChart(selectedItem, city, d);
}

function closeChart() {
  selectedItem = null;
  document.getElementById('chart-container').classList.add('hidden');
  applyFilters();
}

function drawChart(item, city, days) {
  const today = new Date(); today.setHours(0,0,0,0);
  const since = new Date(today); since.setDate(since.getDate() - days);

  // Group by date
  const byDate = {};
  allPrices.forEach(p => {
    const v = vendors.find(v => v.id === p.vendorId);
    if (!v || v.city.toLowerCase() !== city.toLowerCase()) return;
    if (p.item !== item) return;
    const d = new Date(p.date); d.setHours(0,0,0,0);
    if (d < since) return;
    const key = d.toISOString().slice(0,10);
    if (!byDate[key]) byDate[key] = [];
    byDate[key].push(p.pricePerKg);
  });

  const data = Object.entries(byDate).sort((a,b) => a[0].localeCompare(b[0])).map(([date, prices]) => ({
    date: date.slice(5),
    avg: prices.reduce((a,b)=>a+b,0)/prices.length,
    min: Math.min(...prices),
    max: Math.max(...prices)
  }));

  if (!data.length) {
    document.getElementById('chart-svg').innerHTML = `<text x="350" y="100" text-anchor="middle" fill="#9ca3af" font-size="14">No data available</text>`;
    return;
  }

  const W=700, H=200, PAD={top:10,right:10,bottom:24,left:36};
  const allVals = data.flatMap(d=>[d.min,d.max]);
  const minY = Math.floor(Math.min(...allVals)*0.9);
  const maxY = Math.ceil(Math.max(...allVals)*1.1);

  function px(i){ return PAD.left + (i/(data.length-1||1))*(W-PAD.left-PAD.right); }
  function py(v){ return PAD.top + (1-(v-minY)/(maxY-minY||1))*(H-PAD.top-PAD.bottom); }

  const avgPath = data.map((d,i)=>`${i===0?'M':'L'}${px(i)},${py(d.avg)}`).join(' ');
  const minPath = data.map((d,i)=>`${i===0?'M':'L'}${px(i)},${py(d.min)}`).join(' ');
  const maxPath = data.map((d,i)=>`${i===0?'M':'L'}${px(i)},${py(d.max)}`).join(' ');

  // Y axis labels
  const yTicks = [minY, Math.round((minY+maxY)/2), maxY];
  const yLabels = yTicks.map(t=>`<text x="${PAD.left-4}" y="${py(t)+4}" text-anchor="end" fill="#9ca3af" font-size="10">₹${t}</text>`).join('');

  // X axis labels (show every nth)
  const step = Math.ceil(data.length/5);
  const xLabels = data.filter((_,i)=>i%step===0||i===data.length-1).map((d,_,arr)=>{
    const i = data.indexOf(d);
    return `<text x="${px(i)}" y="${H-4}" text-anchor="middle" fill="#9ca3af" font-size="10">${d.date}</text>`;
  }).join('');

  // Grid lines
  const grid = yTicks.map(t=>`<line x1="${PAD.left}" y1="${py(t)}" x2="${W-PAD.right}" y2="${py(t)}" stroke="#f3f4f6" stroke-width="1"/>`).join('');

  document.getElementById('chart-svg').innerHTML = `
    ${grid}${yLabels}${xLabels}
    <path d="${minPath}" fill="none" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="4,2"/>
    <path d="${maxPath}" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="4,2"/>
    <path d="${avgPath}" fill="none" stroke="#16a34a" stroke-width="2"/>
    ${data.map((d,i)=>`<circle cx="${px(i)}" cy="${py(d.avg)}" r="3" fill="#16a34a"/>`).join('')}
  `;
}

// ─── COMPARE ──────────────────────────────────────────────────────────────────
function populateItemSuggestions() {
  const items = [...new Set(Object.keys(BASE_PRICES))].sort();
  document.getElementById('item-suggestions').innerHTML = items.map(i=>`<option value="${i}">`).join('');
}

function runCompare() {
  const item = document.getElementById('cmp-item').value.trim();
  const city = document.getElementById('cmp-city').value;
  if (!item) { showToast('Enter an item name'); return; }

  const today = new Date(); today.setHours(0,0,0,0);
  const prices = allPrices.filter(p => {
    const v = vendors.find(v => v.id === p.vendorId);
    const pd = new Date(p.date); pd.setHours(0,0,0,0);
    return p.item.toLowerCase() === item.toLowerCase()
      && v && v.city.toLowerCase() === city.toLowerCase()
      && pd.getTime() === today.getTime();
  }).map(p => ({ ...p, vendor: vendors.find(v => v.id === p.vendorId) }));

  // Deduplicate by vendor
  const seen = new Set(); const deduped = [];
  prices.forEach(p => { if(!seen.has(p.vendorId)){seen.add(p.vendorId);deduped.push(p);} });
  const sorted = deduped.sort((a,b) => a.pricePerKg - b.pricePerKg);

  if (!sorted.length) {
    document.getElementById('cmp-stats').classList.add('hidden');
    document.getElementById('cmp-result').innerHTML = `<div class="empty"><div class="empty-icon">🔍</div><p>No prices found for <strong>${item}</strong> in <strong>${city}</strong> today.</p></div>`;
    return;
  }

  const minP = sorted[0].pricePerKg;
  const maxP = sorted[sorted.length-1].pricePerKg;
  const avgP = (sorted.reduce((a,b)=>a+b.pricePerKg,0)/sorted.length).toFixed(1);

  document.getElementById('cmp-stats').classList.remove('hidden');
  document.getElementById('cmp-stats').innerHTML = [
    { label:'Cheapest', val:`₹${minP}`, bg:'#f0fdf4', col:'#16a34a' },
    { label:'Average',  val:`₹${avgP}`, bg:'#eff6ff', col:'#2563eb' },
    { label:'Highest',  val:`₹${maxP}`, bg:'#fef2f2', col:'#ef4444' }
  ].map(s=>`<div class="cmp-stat" style="background:${s.bg}">
    <div class="cmp-val" style="color:${s.col}">${s.val}</div>
    <div class="cmp-label" style="color:#6b7280">${s.label} per unit</div>
  </div>`).join('');

  document.getElementById('cmp-result').innerHTML = `<div class="compare-table">
    <table>
      <thead><tr>
        <th>Rank</th><th>Mandi</th><th>Location</th><th>Phone</th>
        <th>Price/unit</th><th>Stock</th><th>vs Cheapest</th>
      </tr></thead>
      <tbody>
        ${sorted.map((r,i)=>{
          const sc = r.stock==='available'?'background:#dcfce7;color:#15803d':r.stock==='limited'?'background:#fef3c7;color:#92400e':'background:#fee2e2;color:#991b1b';
          const rank = i===0?'🥇':i===1?'🥈':i===2?'🥉':`#${i+1}`;
          return `<tr${i===0?' class="best-row"':''}>
            <td>${rank}</td>
            <td style="font-weight:600">${r.vendor?.mandiName}</td>
            <td style="color:#6b7280">${r.vendor?.city}, ${r.vendor?.pincode}</td>
            <td style="color:#6b7280">${r.vendor?.phone||'—'}</td>
            <td class="price-cell">₹${r.pricePerKg}</td>
            <td><span class="stock-badge" style="${sc}">${r.stock.replace('_',' ')}</span></td>
            <td${i===0?' class="savings-best"':' style="color:#6b7280"'}>${i===0?'Best Deal!':'₹'+(r.pricePerKg-minP).toFixed(1)+' more'}</td>
          </tr>`;
        }).join('')}
      </tbody>
    </table>
  </div>`;
}

// ─── ALERTS ───────────────────────────────────────────────────────────────────
function createAlert() {
  const email = document.getElementById('al-email').value.trim();
  const item = document.getElementById('al-item').value.trim();
  const city = document.getElementById('al-city').value;
  const targetPrice = parseFloat(document.getElementById('al-price').value);
  const msgEl = document.getElementById('al-msg');

  if (!email || !item || !targetPrice) {
    msgEl.innerHTML = `<div class="msg-box msg-err">Please fill all fields.</div>`; return;
  }

  // Check if already triggered (any price today <= target)
  const today = new Date(); today.setHours(0,0,0,0);
  const triggered = allPrices.some(p => {
    const v = vendors.find(v=>v.id===p.vendorId);
    const pd = new Date(p.date); pd.setHours(0,0,0,0);
    return p.item.toLowerCase()===item.toLowerCase() && v && v.city.toLowerCase()===city.toLowerCase()
      && pd.getTime()===today.getTime() && p.pricePerKg <= targetPrice;
  });

  const alert = { id: Date.now().toString(), userEmail:email, item, city, targetPrice, isTriggered:triggered, createdAt:new Date().toISOString() };
  alerts.push(alert); saveAlerts();
  msgEl.innerHTML = `<div class="msg-box msg-ok">✅ Alert created!${triggered?' Price is already at or below your target today!':''}</div>`;
  document.getElementById('al-item').value = '';
  document.getElementById('al-price').value = '';
}

function fetchAlerts() {
  const email = document.getElementById('al-fetch-email').value.trim();
  if (!email) { showToast('Enter an email address'); return; }
  const myAlerts = alerts.filter(a => a.userEmail === email);
  const el = document.getElementById('alerts-list');
  if (!myAlerts.length) {
    el.innerHTML = `<p style="color:#9ca3af;font-size:14px;text-align:center;padding:1.5rem 0">No alerts found for this email.</p>`;
    return;
  }
  el.innerHTML = myAlerts.map(a => `
    <div class="alert-item${a.isTriggered?' triggered':''}">
      <div>
        <div class="alert-name">${a.item} in ${a.city}${a.isTriggered?'<span class="triggered-badge">TRIGGERED ✓</span>':''}</div>
        <div class="alert-detail">Alert when ≤ ₹${a.targetPrice}/unit</div>
      </div>
      <button class="del-btn" onclick="deleteAlert('${a.id}','${email}')">✕</button>
    </div>`).join('');
}

function deleteAlert(id, email) {
  alerts = alerts.filter(a => a.id !== id);
  saveAlerts();
  fetchAlerts();
  // re-set email field
  document.getElementById('al-fetch-email').value = email;
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────
function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-password').value;
  const msgEl = document.getElementById('login-msg');
  const vendor = vendors.find(v => v.email === email && v.password === pass);
  if (!vendor) {
    msgEl.innerHTML = `<div class="msg-box msg-err">Invalid email or password.</div>`; return;
  }
  currentVendor = vendor;
  localStorage.setItem('mandibhav_vendor', JSON.stringify(vendor));
  updateAuthNav();
  showToast('Welcome back, ' + vendor.name + '!');
  showPage('dashboard');
}

function doRegister() {
  const name = document.getElementById('reg-name').value.trim();
  const mandiName = document.getElementById('reg-mandi').value.trim();
  const city = document.getElementById('reg-city').value.trim();
  const pincode = document.getElementById('reg-pin').value.trim();
  const phone = document.getElementById('reg-phone').value.trim();
  const email = document.getElementById('reg-email').value.trim();
  const password = document.getElementById('reg-pass').value;
  const msgEl = document.getElementById('reg-msg');

  if (!name||!mandiName||!city||!email||!password) {
    msgEl.innerHTML = `<div class="msg-box msg-err">Please fill all required fields.</div>`; return;
  }
  if (vendors.find(v=>v.email===email)) {
    msgEl.innerHTML = `<div class="msg-box msg-err">Email already registered.</div>`; return;
  }
  if (password.length < 6) {
    msgEl.innerHTML = `<div class="msg-box msg-err">Password must be at least 6 characters.</div>`; return;
  }
  const newVendor = { id:'v'+Date.now(), name, mandiName, city, pincode, phone, email, password };
  vendors.push(newVendor);
  currentVendor = newVendor;
  localStorage.setItem('mandibhav_vendor', JSON.stringify(newVendor));
  updateAuthNav();
  showToast('Registered successfully! Welcome, ' + name);
  showPage('dashboard');
}

function logout() {
  currentVendor = null;
  localStorage.removeItem('mandibhav_vendor');
  updateAuthNav();
  showPage('home');
  showToast('Logged out successfully');
}

// ─── DASHBOARD ────────────────────────────────────────────────────────────────
function renderDashboard() {
  if (!currentVendor) { showPage('login'); return; }
  document.getElementById('dash-subtitle').textContent = `${currentVendor.mandiName} · ${currentVendor.city}`;

  const today = new Date(); today.setHours(0,0,0,0);
  const myPrices = allPrices.filter(p => {
    const pd = new Date(p.date); pd.setHours(0,0,0,0);
    return p.vendorId === currentVendor.id && pd.getTime()===today.getTime();
  });

  // Deduplicate
  const seen=new Set(); const deduped=[];
  myPrices.forEach(p=>{if(!seen.has(p.item)){seen.add(p.item);deduped.push(p);}});

  const avg = deduped.length ? (deduped.reduce((a,b)=>a+b.pricePerKg,0)/deduped.length).toFixed(1) : '—';
  document.getElementById('dash-stats').innerHTML = [
    {icon:'📋', val:deduped.length, label:'Items Listed Today'},
    {icon:'💰', val:deduped.length?`₹${avg}`:'—', label:'Avg Price'},
    {icon:'✅', val:deduped.filter(p=>p.stock==='available').length, label:'In Stock'}
  ].map(s=>`<div class="stat-card">
    <div class="stat-icon">${s.icon}</div>
    <div class="stat-val">${s.val}</div>
    <div class="stat-label">${s.label}</div>
  </div>`).join('');

  renderMyPricesTable(deduped);
}

function renderMyPricesTable(prices) {
  const el = document.getElementById('my-prices-table');
  if (!prices.length) {
    el.innerHTML = `<div class="empty" style="border:none"><div class="empty-icon">📋</div>
      <p>No prices posted today.</p>
      <button class="btn-primary" style="margin-top:12px" onclick="switchTab('add')">Add Your First Price</button></div>`;
    return;
  }
  el.innerHTML = `<table>
    <thead><tr><th>Item</th><th>Category</th><th>Price</th><th>Unit</th><th>Stock</th><th></th></tr></thead>
    <tbody>
      ${prices.map(p=>{
        const sc=p.stock==='available'?'background:#dcfce7;color:#15803d':p.stock==='limited'?'background:#fef3c7;color:#92400e':'background:#fee2e2;color:#991b1b';
        return `<tr>
          <td style="font-weight:600">${p.item}</td>
          <td style="color:#6b7280">${p.category}</td>
          <td style="font-weight:700;color:#16a34a;font-size:15px">₹${p.pricePerKg}</td>
          <td style="color:#6b7280">${p.unit}</td>
          <td><span class="stock-badge" style="${sc}">${p.stock.replace('_',' ')}</span></td>
          <td><button onclick="deleteMyPrice('${p.id}')" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px">🗑️</button></td>
        </tr>`;
      }).join('')}
    </tbody>
  </table>`;
}

function deleteMyPrice(id) {
  allPrices = allPrices.filter(p => p.id !== id);
  renderDashboard();
  showToast('Price removed');
}

function publishPrice() {
  if (!currentVendor) return;
  const item = document.getElementById('add-item').value.trim();
  const price = parseFloat(document.getElementById('add-price').value);
  const category = document.getElementById('add-cat').value;
  const unit = document.getElementById('add-unit').value;
  const stock = document.getElementById('add-stock').value;
  const msgEl = document.getElementById('add-msg');

  if (!item || !price) { msgEl.innerHTML=`<div class="msg-box msg-err">Item name and price are required.</div>`; return; }

  const today = new Date(); today.setHours(8,0,0,0);
  const newPrice = {
    id: `${currentVendor.id}-${item}-new-${Date.now()}`,
    vendorId: currentVendor.id,
    item, category, pricePerKg: price, unit, stock, date: today
  };
  allPrices.push(newPrice);

  // Check and trigger alerts
  let triggered = 0;
  alerts.forEach(a => {
    if (a.item.toLowerCase()===item.toLowerCase() && a.city.toLowerCase()===currentVendor.city.toLowerCase() && price<=a.targetPrice && !a.isTriggered) {
      a.isTriggered = true; triggered++;
    }
  });
  saveAlerts();

  msgEl.innerHTML=`<div class="msg-box msg-ok">✅ Price published!${triggered?` ${triggered} alert(s) triggered.`:''}</div>`;
  document.getElementById('add-item').value='';
  document.getElementById('add-price').value='';
  renderDashboard();
  switchTab('prices');
}

function switchTab(tab) {
  currentDashTab = tab;
  document.getElementById('tab-content-prices').classList.toggle('hidden', tab!=='prices');
  document.getElementById('tab-content-add').classList.toggle('hidden', tab!=='add');
  document.getElementById('tab-prices').classList.toggle('active', tab==='prices');
  document.getElementById('tab-add').classList.toggle('active', tab==='add');
}

// ─── TOAST ───────────────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.style.display = 'block';
  setTimeout(()=>{ t.style.display='none'; }, 3000);
}

// ─── BOOT ─────────────────────────────────────────────────────────────────────
updateAuthNav();
renderHome();
</script>
</body>
</html>
